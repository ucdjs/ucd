{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true
    },
    "lint": {
    },
    "typecheck": {
      "outputs": [
        ".cache/tsbuildinfo.json",
        "wrangler-types.d.ts"
      ]
    }
  }
}
