{
  "tailwindCSS.experimental.configFile": "./apps/web/src/globals.css",
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "apps/api/wrangler.jsonc",
        "cmd": "pnpm --filter ./apps/api run generate:types",
        "isAsync": true
      },
      {
        "match": "apps/store/wrangler.jsonc",
        "cmd": "pnpm --filter ./apps/store run generate:types",
        "isAsync": true
      },
      {
        "match": "vscode/package.json",
        "cmd": "pnpm --filter ./vscode run ext:gen",
        "isAsync": true
      }
    ]
  },
  "workbench.editor.customLabels.enabled": true,
  "workbench.editor.customLabels.patterns": {
    "**/pipeline-server/src/server/routes/**/*.ts": "pipeline-server • ${filename}",
    "**/api/src/routes/**/*.ts": "api • ${dirname} • ${filename}",
    "**/store/src/routes/**/*.ts": "store • ${filename}",
  },
  "testing.automaticallyOpenTestResults": "neverOpen",
  "files.associations": {
    "tsconfig.json": "jsonc",
    "tsconfig.*.json": "jsonc",
    "**/tooling/tsconfig/base.json": "jsonc",
    "**/tooling/tsconfig/base.*.json": "jsonc"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    // group test files e.g.
    // utils.windows.test.ts, utils.unix.test.ts, utils.test.ts
    "*.test.ts": "$(capture).*.test.ts"
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.experimental.useTsgo": true,
}
