{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./base.build.json",
  "compilerOptions": {
    "paths": {
      "@ucdjs/cli": ["../../packages/cli/src/cli.ts"],
      "@ucdjs/env": ["../../packages/env/src/index.ts"],
      "@ucdjs/client": ["../../packages/client/src/index.ts"],
      "@ucdjs/codegen": ["../../packages/codegen/src/index.ts"],
      "@ucdjs/lockfile": ["../../packages/lockfile/src/index.ts"],
      "@ucdjs/lockfile/test-utils": ["../../packages/lockfile/src/test-utils/index.ts"],
      "@ucdjs/schemas": ["../../packages/schemas/src/index.ts"],
      "@ucdjs/ucd-store": ["../../packages/ucd-store/src/index.ts"],

      // Shared UI
      "@ucdjs-internal/shared-ui": ["../../packages/shared-ui/src/index.ts"],
      "@ucdjs-internal/shared-ui/components": ["../../packages/shared-ui/src/components.ts"],
      "@ucdjs-internal/shared-ui/lib/*": ["../../packages/shared-ui/src/lib/*.ts"],
      "@ucdjs-internal/shared-ui/hooks": ["../../packages/shared-ui/src/hooks/index.ts"],
      "@ucdjs-internal/shared-ui/styles.css": ["../../packages/shared-ui/src/styles/globals.css"],

      // utility packages
      "@ucdjs-internal/shared": ["../../packages/shared/src/index.ts"],
      "@ucdjs-internal/worker-utils": ["../../packages/worker-utils/src/index.ts"],
      "@ucdjs-internal/worker-utils/h3": ["../../packages/worker-utils/src/h3.ts"],
      "@ucdjs-internal/worker-utils/setups": ["../../packages/worker-utils/src/setups.ts"],
      "@ucdjs-internal/worker-utils/constants": ["../../packages/worker-utils/src/constants.ts"],
      "@ucdjs-internal/worker-utils/environment": ["../../packages/worker-utils/src/environment.ts"],
      "@ucdjs-internal/worker-utils/tasks": ["../../packages/worker-utils/src/tasks/index.ts"],
      "@ucdjs/utils": ["../../packages/utils/src/index.ts"],
      "@ucdjs/path-utils": ["../../packages/path-utils/src/index.ts"],

      // fs backend
      "@ucdjs/fs-backend": ["../../packages/fs-backend/src/index.ts"],
      "@ucdjs/fs-backend/backends/http": ["../../packages/fs-backend/src/backends/http.ts"],
      "@ucdjs/fs-backend/backends/node": ["../../packages/fs-backend/src/backends/node.ts"],
      "@ucdjs/fs-backend/utils": ["../../packages/fs-backend/src/utils.ts"],

      // pipeline packages
      "@ucdjs/pipeline-core": ["../../packages/pipelines/pipeline-core/src/index.ts"],
      "@ucdjs/pipeline-core/outputs": ["../../packages/pipelines/pipeline-core/src/outputs/index.ts"],
      "@ucdjs/pipeline-core/sources": ["../../packages/pipelines/pipeline-core/src/sources/index.ts"],
      "@ucdjs/pipeline-core/transforms": ["../../packages/pipelines/pipeline-core/src/transforms/index.ts"],
      "@ucdjs/pipeline-core/tracing": ["../../packages/pipelines/pipeline-core/src/tracing/index.ts"],
      "@ucdjs/pipeline-graph": ["../../packages/pipelines/pipeline-graph/src/index.ts"],
      "@ucdjs/pipeline-executor": ["../../packages/pipelines/pipeline-executor/src/index.ts"],
      "@ucdjs/pipeline-executor/graph": ["../../packages/pipelines/pipeline-executor/src/graph.ts"],
      "@ucdjs/pipeline-executor/node": ["../../packages/pipelines/pipeline-executor/src/runtime/node.ts"],
      "@ucdjs/pipeline-executor/traces": ["../../packages/pipelines/pipeline-executor/src/run/traces.ts"],
      "@ucdjs/pipeline-loader": ["../../packages/pipelines/pipeline-loader/src/index.ts"],
      "@ucdjs/pipeline-loader/discover": ["../../packages/pipelines/pipeline-loader/src/discover.ts"],
      "@ucdjs/pipeline-server": ["../../packages/pipelines/pipeline-server/src/server/app.ts"],
      "@ucdjs/pipeline-presets": ["../../packages/pipelines/pipeline-presets/src/index.ts"],

      // Test utils
      "@ucdjs/test-utils": ["../../packages/test-utils/src/index.ts"],
      // we use alias for test utils to avoid having to build it during development
      "#test-utils/mock-store": ["../../packages/test-utils/src/mock-store/index.ts"],
      "#test-utils/msw": ["../../packages/test-utils/src/msw.ts"],
      "#test-utils": ["../../packages/test-utils/src/index.ts"],
      "#test-utils/fs-backends": ["../../packages/test-utils/src/fs-backends/index.ts"],
      "#test-utils/fs-bridges": ["../../packages/test-utils/src/fs-bridges/index.ts"],
      "#test-utils/matchers": ["../../packages/test-utils/src/matchers/types.d.ts"],
      "#test-utils/pipelines": ["../../packages/test-utils/src/pipelines/index.ts"],

      // Internal Test Utils
      "#internal/test-utils/conditions": ["../../test/utils/conditions.ts"]
    }
  },
  "include": ["${configDir}/**/*.ts", "${configDir}/**/*.tsx"],
  "exclude": ["${configDir}/node_modules/", "${configDir}/dist/", "${configDir}/eslint.config.js"]
}
