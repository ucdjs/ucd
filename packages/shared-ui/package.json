{
  "name": "@ucdjs-internal/shared-ui",
  "version": "0.1.8",
  "type": "module",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "homepage": "https://github.com/ucdjs/ucd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ucdjs/ucd.git",
    "directory": "packages/shared-ui"
  },
  "bugs": {
    "url": "https://github.com/ucdjs/ucd/issues"
  },
  "sideEffects": [
    "*.css",
    "dist/styles/**"
  ],
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#ui/*": "./src/ui/*.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./components": "./dist/components.mjs",
    "./hooks": "./dist/hooks/index.mjs",
    "./lib/theme-script": "./dist/lib/theme-script.mjs",
    "./lib/utils": "./dist/lib/utils.mjs",
    "./styles.css": "./dist/styles/globals.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.13"
  },
  "scripts": {
    "build": "tsdown --tsconfig=./tsconfig.build.json",
    "dev": "tsdown --watch",
    "clean": "git clean -xdf dist node_modules",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@base-ui/react": "catalog:frontend",
    "@base-ui/utils": "catalog:frontend",
    "@cmdi/base-ui": "catalog:frontend",
    "@fontsource-variable/inter": "catalog:frontend",
    "class-variance-authority": "catalog:frontend",
    "clsx": "catalog:frontend",
    "lucide-react": "catalog:frontend",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "shiki": "catalog:runtime",
    "tailwind-merge": "catalog:frontend",
    "tailwindcss": "catalog:build",
    "tw-animate-css": "catalog:frontend",
    "zod": "catalog:runtime"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "catalog:lint",
    "@luxass/eslint-config": "catalog:lint",
    "@rollup/plugin-babel": "catalog:build",
    "@testing-library/jest-dom": "catalog:test",
    "@testing-library/react": "catalog:test",
    "@testing-library/user-event": "catalog:test",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@ucdjs-tooling/tsconfig": "workspace:*",
    "@ucdjs-tooling/tsdown-config": "workspace:*",
    "babel-plugin-react-compiler": "catalog:build",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "eslint-plugin-react-hooks": "catalog:lint",
    "eslint-plugin-react-refresh": "catalog:lint",
    "jsdom": "catalog:test",
    "publint": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:test"
  },
  "publishConfig": {
    "access": "public"
  }
}
