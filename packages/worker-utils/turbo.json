{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "generate:types": {
      "outputs": [
        "wrangler-types.d.ts"
      ]
    }
  }
}
