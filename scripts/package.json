{
  "name": "@ucdjs/ucdjs-scripts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "homepage": "https://github.com/ucdjs/ucd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ucdjs/ucd.git",
    "directory": "scripts"
  },
  "bugs": {
    "url": "https://github.com/ucdjs/ucd/issues"
  },
  "imports": {
    "#lib/*": "./src/lib/*.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "ucdjs-scripts": "./bin/ucdjs-scripts.js"
  },
  "engines": {
    "node": ">=24.13"
  },
  "scripts": {
    "clean": "git clean -xdf dist node_modules .cache .turbo",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p jsconfig.json"
  },
  "dependencies": {
    "@ucdjs-internal/shared": "workspace:*",
    "@ucdjs/client": "workspace:*",
    "@ucdjs/moonbeam": "workspace:*",
    "@ucdjs/release-scripts": "catalog:build",
    "@ucdjs/schemas": "workspace:*",
    "@unicode-utils/core": "catalog:runtime",
    "apache-autoindex-parse": "catalog:runtime",
    "nanotar": "catalog:build",
    "wrangler": "catalog:backend"
  },
  "devDependencies": {
    "@luxass/eslint-config": "catalog:lint",
    "@types/node": "catalog:types",
    "@ucdjs-tooling/tsconfig": "workspace:*",
    "eslint": "catalog:lint",
    "typescript": "catalog:build"
  }
}
